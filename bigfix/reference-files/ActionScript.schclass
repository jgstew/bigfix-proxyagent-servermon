lexClass:
	name			= global
	parent:file		= <*.ActionScript>

lexClass:
	name		= comment
	parent		= global
	start:tag	='//'
	skip:Tag	= '\\\r\n', '\\\n\r', '\\\n', '\\\r'
	end:separators = @eol
	txt:colorFG	= 0x00A000
	DisplayName		= 'Comment (Single-Line)'

lexClass:
	name			= string
	parent:dyn		= global
	start:Tag		= '"'
	skip:Tag		= '\\"', '\\\r\n', '\\\n\r', '\\\n', '\\\r'
	end:Tag			= '"', @eol
	txt:colorFG		= 0xE00000
	DisplayName		= 'String (Double Quotes)'

lexClass:
	name			= relevance
	parent:dyn		= global
	children		= url
	start:Tag		= '{'
	skip:Tag		= '\\"', '\\\r\n', '\\\n\r', '\\\n', '\\\r'
	end:Tag			= '}', @eol
	txt:colorFG		= 0xff00ff
	DisplayName		= 'String (Double Quotes)'

lexClass:
	name		= url
	parent:dyn	= global
	previous:tag	= @specs, ' ', '\t', @eol
	start:Tag		= 'http:'
	end:separators	= ' ', '\t', '*', '"', @eol
	txt:colorBK	= 0xC0FFC0
	txt:Underline	= 1
	DisplayName		= 'URL'

lexClass:
	name = download_now_as
	parent = global
	previous:tag = @eol
	token:tag = 'download now as'
	txt:colorFG	= 0x0000FF

lexClass:
	name = download_as
	parent = global
	previous:tag = @eol
	token:tag = 'download as'
	txt:colorFG	= 0x0000FF

lexClass:
	name = download
	parent = global
	previous:tag = @eol
	token:tag = 'download'
	txt:colorFG	= 0x0000FF

lexClass:
	name = setting_delete
	parent = global
	previous:tag = @eol
	token:tag = 'setting delete'
	txt:colorFG	= 0x0000FF

lexClass:
	name = setting
	parent = global
	previous:tag = @eol
	token:tag = 'setting'
	txt:colorFG	= 0x0000FF

lexClass:
	name = keywords
	ParseOnScreen = 0
	parent = global
	children = 0
	DisplayName = 'Keyword'

	token:tag = 'delete'
	token:tag = 'copy'
	token:tag = 'move'
	token:tag = 'regset64'
	token:tag = 'regdelete64'
	token:tag = 'script64'
	token:tag = 'regset'
	token:tag = 'regdelete'
	token:tag = 'fixlet delete'
	token:tag = 'pause while'
	token:tag = 'enable gathering'
	token:tag = 'fixlet close'
	token:tag = 'fixlet restore'
	token:tag = 'browse to'
	token:tag = 'dos'
